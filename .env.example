# NBA/NFL Highlights Agent - Environment Variables
# Copy this file to .env and fill in your credentials

# Telegram Configuration (optional - bot won't send messages without these)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORT_CHAT_ID=

# Facebook Configuration (optional - uploads will be skipped without these)
FB_ACCESS_TOKEN=
FB_PAGE_ID=

# YouTube Configuration (optional - uploads will be skipped without these)
YOUTUBE_TOKEN_JSON=

# NVIDIA API Key for AI headline/SEO generation (optional - uses fallback if missing)
NVIDIA_API_KEY=

# Google Gemini API Key for deep video analysis (optional)
GEMINI_API_KEY=
